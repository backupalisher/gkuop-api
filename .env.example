# Email конфигурация
IMAP_SERVER=imap.yandex.ru
EMAIL=email
EMAIL_PASSWORD=password

# Database конфигурация
DB_HOST=localhost
DB_PORT=5432
DB_NAME=table
DB_USER=name
DB_PASSWORD=pass

# Парсер конфигурация
MAX_EMAILS_PER_RUN=100
IMAP_FOLDER=folders

# Веб-интерфейс (логин/пароль — хранятся в виде SHA-256 хешей)
# Сгенерировать хеш: python -c "import hashlib; print(hashlib.sha256(b'admin').hexdigest())"
WEB_USER_HASH=
WEB_PASSWORD_HASH=
